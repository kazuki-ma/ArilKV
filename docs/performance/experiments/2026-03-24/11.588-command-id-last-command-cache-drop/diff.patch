+#[test]
+fn combined_input_and_last_command_caches_repeated_simple_command_ids() {
+    let metrics = ServerMetrics::default();
+    let client_id = metrics.register_client(None, None);
+
+    metrics.add_client_input_bytes_and_command(client_id, 3, CommandId::Get, b"GET", None);
+    metrics.add_client_input_bytes_and_command(client_id, 5, CommandId::Get, b"GET", None);
+
+    let clients = metrics.clients.lock().unwrap();
+    let client = clients.get(&client_id).unwrap();
+    assert_eq!(client.total_input_bytes, 8);
+    assert_eq!(client.last_command, b"get");
+    assert_eq!(client.last_command_id, CommandId::Get);
+    assert!(!client.last_command_has_subcommand);
+}
