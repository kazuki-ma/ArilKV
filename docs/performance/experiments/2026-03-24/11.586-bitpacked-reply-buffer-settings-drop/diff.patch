+#[test]
+fn reply_buffer_settings_snapshot_tracks_independent_updates() {
+    let metrics = ServerMetrics::default();
+
+    let default_settings = metrics.reply_buffer_settings_snapshot();
+    assert_eq!(
+        default_settings.peak_reset_time,
+        Some(Duration::from_millis(
+            REPLY_BUFFER_DEFAULT_PEAK_RESET_TIME_MILLIS
+        ))
+    );
+    assert!(default_settings.resizing_enabled);
+    assert!(default_settings.copy_avoidance_enabled);
+
+    metrics.set_reply_buffer_peak_reset_time_millis(None);
+    metrics.set_reply_buffer_resizing_enabled(false);
+    metrics.set_reply_copy_avoidance_enabled(false);
+
+    let disabled_settings = metrics.reply_buffer_settings_snapshot();
+    assert_eq!(disabled_settings.peak_reset_time, None);
+    assert!(!disabled_settings.resizing_enabled);
+    assert!(!disabled_settings.copy_avoidance_enabled);
+
+    metrics.reset_reply_buffer_peak_reset_time();
+    metrics.set_reply_buffer_resizing_enabled(true);
+    metrics.set_reply_copy_avoidance_enabled(true);
+
+    let restored_settings = metrics.reply_buffer_settings_snapshot();
+    assert_eq!(
+        restored_settings.peak_reset_time,
+        Some(Duration::from_millis(
+            REPLY_BUFFER_DEFAULT_PEAK_RESET_TIME_MILLIS
+        ))
+    );
+    assert!(restored_settings.resizing_enabled);
+    assert!(restored_settings.copy_avoidance_enabled);
+}
