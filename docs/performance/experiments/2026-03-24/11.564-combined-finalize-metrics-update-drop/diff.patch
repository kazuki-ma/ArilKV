+    pub fn record_client_command_completion(
+        &self,
+        client_id: ClientId,
+        output_bytes: u64,
+        commands_processed: u64,
+    ) {
+        if output_bytes == 0 && commands_processed == 0 {
+            return;
+        }
+
+        let mut now = None;
+        let mut settings = None;
+        if output_bytes != 0 {
+            now = Some(Instant::now());
+            settings = Some(self.reply_buffer_settings_snapshot());
+        }
+
+        if let Ok(mut clients) = self.clients.lock()
+            && let Some(client) = clients.get_mut(&client_id)
+        {
+            if output_bytes != 0 {
+                let observed_now = now.expect("output path initializes timestamp");
+                let reply_settings = settings.expect("output path initializes settings");
+                client.total_output_bytes = client.total_output_bytes.saturating_add(output_bytes);
+                client.last_activity = observed_now;
+                client.observe_reply_bytes(output_bytes as usize, reply_settings, observed_now);
+            }
+            if commands_processed != 0 {
+                client.total_commands = client.total_commands.saturating_add(commands_processed);
+            }
+        }
+    }
