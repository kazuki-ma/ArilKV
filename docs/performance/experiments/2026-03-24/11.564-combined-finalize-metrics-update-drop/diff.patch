+#[test]
+fn client_command_completion_updates_output_activity_and_command_count_together() {
+    let metrics = ServerMetrics::default();
+    let client_id = metrics.register_client(None, None);
+
+    let initial_activity = metrics
+        .clients
+        .lock()
+        .unwrap()
+        .get(&client_id)
+        .unwrap()
+        .last_activity;
+
+    std::thread::sleep(Duration::from_millis(2));
+    metrics.record_client_command_completion(client_id, 7, 3);
+
+    {
+        let clients = metrics.clients.lock().unwrap();
+        let client = clients.get(&client_id).unwrap();
+        assert!(client.last_activity > initial_activity);
+        assert_eq!(client.total_output_bytes, 7);
+        assert_eq!(client.total_commands, 3);
+    }
+
+    let after_output_activity = metrics
+        .clients
+        .lock()
+        .unwrap()
+        .get(&client_id)
+        .unwrap()
+        .last_activity;
+
+    metrics.record_client_command_completion(client_id, 0, 2);
+    let clients = metrics.clients.lock().unwrap();
+    let client = clients.get(&client_id).unwrap();
+    assert_eq!(client.last_activity, after_output_activity);
+    assert_eq!(client.total_output_bytes, 7);
+    assert_eq!(client.total_commands, 5);
+}
